OLLAMA_BASE_URL=http://127.0.0.1:11434
SLACK_APP_TOKEN=xapp-your-token-here
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL=#institutional-memory
SLACK_WEBHOOK_URL=
# Unprompted replies: * = any channel the bot is in; empty = SLACK_CHANNEL only
LISTENER_CHANNELS=*
# Code default is 0.80; use 0.65 for demos with mock corpus
UNPROMPTED_THRESHOLD=0.65
THREAD_THRESHOLD=0.65
# Optional per-channel unprompted overrides, e.g. #general:0.85,C123ABC:0.70
LISTENER_CHANNEL_THRESHOLDS=
# Optional: shell command after listener writes company/inbox/slack/*.md (empty = heartbeat only)
OPENCLAW_WAKE_CMD=
